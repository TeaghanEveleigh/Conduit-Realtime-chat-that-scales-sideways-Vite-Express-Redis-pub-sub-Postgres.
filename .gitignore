# ─── Dependencies ────────────────────────────────
node_modules/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ─── Build outputs ───────────────────────────────
dist/
build/
out/
.vite/
.turbo/
*.tsbuildinfo

# ─── Environment & secrets ───────────────────────
.env
.env.*
!.env.example
!.env.*.example

# ─── Logs ────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Testing & coverage ──────────────────────────
coverage/
.nyc_output/
playwright-report/
playwright/.cache/
test-results/
.vitest-cache/

# ─── Caches ──────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.npm/

# ─── TypeScript / IDE ────────────────────────────
.tsbuildinfo
*.tsbuildinfo

# VS Code (keep shared settings, ignore personal)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains
.idea/
*.iml

# ─── OS junk ─────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Local infra & databases ─────────────────────
*.sqlite
*.sqlite3
*.db
pgdata/
redis-data/

# ─── Drizzle / migrations cache ──────────────────
.drizzle/

# ─── Docker volumes (if mounted locally) ─────────
docker-data/

# ─── Misc ────────────────────────────────────────
*.pem
*.key
*.crt